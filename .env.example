# ===========================================
# Environment Configuration
# Copy this file to .env and fill in your values
# ===========================================

# Application URL (public base URL of the app)
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# Authentication Secret (min 32 characters)
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-key-at-least-32-characters-long

# Database Connection (PostgreSQL)
# Format: postgres://user:password@host:port/database
DATABASE_URL=postgres://user:password@localhost:5432/dashboard

# ===========================================
# Optional Configuration
# ===========================================

# Email Service (Resend) — used for password reset emails.
# When unset, reset links are logged to the server console instead.
# RESEND_API_KEY=re_xxxxxxxxxxxx

# Email sender address (must be a verified domain in Resend)
# BETTER_AUTH_EMAIL=noreply@yourdomain.com

# Skip environment validation (not recommended for production)
# SKIP_ENV_VALIDATION=true
